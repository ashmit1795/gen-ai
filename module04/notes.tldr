							"attrs": {
								"dir": "auto"
							},
							"content": [
								{
									"type": "text",
									"text": "const groq = new Groq({ apiKey: process.env.GROQ_API_KEY });"
								}
							]
						},
						{
							"type": "paragraph",
							"attrs": {
								"dir": "auto"
							}
						},
						{
							"type": "paragraph",
							"attrs": {
								"dir": "auto"
							},
							"content": [
								{
									"type": "text",
									"text": "export async function main() {"
