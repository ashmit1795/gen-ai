												{
													"type": "text",
													"marks": [
														{
															"type": "bold"
														}
													],
													"text": "presence_penalty"
												},
												{
													"type": "text",
													"text": ": Number between -2.0 and 2.0."
												}
											]
										},
										{
											"type": "paragraph",
											"attrs": {
												"dir": "auto"
											},
											"content": [
												{
													"type": "text",
													"text": "Positive values penalize new tokens based on whether they appear in the text so"
												}
											]
										},
										{
											"type": "paragraph",
											"attrs": {
												"dir": "auto"
											},
											"content": [
